flowchart TD
    subgraph ENTRIES ["Entry Points"]
        direction LR
        HB(["heartbeat.ps1\n(watchdog)"])
        RAG(["run_aider.ps1\n-FromGraph"])
        HUMAN(["Human / Copilot CLI"])
    end

    OC["opencode\n(oh-my-opencode-slim)"]
    ORCH["orchestrator\ndeepseek-v4-flash\norchestrator\nRoutes -- never codes"]
    DB[("task_graph\n.task_graph.db")]
    COUNCIL["council\nstep-3.5-flash\n(council variant)\nConsensus + merge"]

    subgraph EXEC ["Execution Layer"]
        direction LR
        SCOUT["scout\nstep-3.5-flash\nCodebase search\nContract output only"]
        PATCHER["patcher\nstep-3.5-flash\nExact hotfix / known-file\n(route into aider)"]
        PI["pi\nstep-3.5-flash\nInner harness loop"]
        FIXER["fixer / coder\nstep-3.5-flash\nMulti-file packets -> aider"]
        AIDER["aider\nstep-3.5-flash\nLeaf editor\n(1 packet . 1 file)"]
        DEBUGGER["debugger\nqwen3.6-35b\nStack traces / QA"]
        HANDYMAN["handyman\nstep-3.5-flash\nMechanical file ops"]
    end

    subgraph PLAN ["Planning Lane"]
        direction LR
        ORACLE["oracle / planner / designer\nqwen3.6-35b-a3b\nSpec + sig + stubs"]
        GEMMA_PLANNER["planner (gemma)\ngemma-4-26b-a4b-it\nSpec + sig + stubs"]
        THINKER["thinker\nqwen3.6-35b\nFirst-principles fallback\n(stuck 2+ attempts)"]
    end

    subgraph EVIDENCE ["Evidence Lane"]
        direction TB
        OBSERVER["observer\nqwen3-vl-30b-a3b-instruct\nVisual inspection / audit"]
        RESEARCHER["researcher\ndeepseek-v4-flash\n3-hop web+docs+files\n(absorbed librarian)"]
        SUMMARIZER["summarizer\ngranite-4.1-8b\nSPO triplet extraction"]
    end

    HUMAN -->|"task prompt"| OC
    RAG -->|"AIDER DIRECT: [task_id=X]"| OC
    HB -->|"stall -> kill+relaunch"| OC
    OC --> ORCH
    ORCH -->|"task graph dispatch / status"| DB

    ORCH -->|"unknown surface only"| SCOUT
    ORCH -->|"known-file hotfix\nskip scout"| PATCHER
    ORCH -->|"smoke test"| PI
    ORCH -->|"multi-file / ambiguous"| FIXER
    ORCH -->|"plan / spec"| ORACLE
    ORCH -->|"plan / spec"| GEMMA_PLANNER
    ORCH -->|"logic stalemate\nwith evidence pack"| THINKER
    ORCH -->|"visual inspect"| OBSERVER
    ORCH -->|"evidence / web / docs"| RESEARCHER
    ORCH -->|"AIDER DIRECT: [task_id=X]"| AIDER

    SCOUT --> DB
    SCOUT -->|"bug report"| HANDYMAN
    PATCHER --> DB
    PATCHER -->|"route into aider"| AIDER
    PI -->|"failure / trace"| DEBUGGER
    PI -->|"run fails / tests fail"| DEBUGGER
    PI -->|"edit packet"| AIDER
    PI --> DB
    FIXER --> DB
    FIXER -->|"status / result"| DB
    FIXER -->|"bounded edit packet\n(1 file . 1 concern)"| AIDER
    FIXER -->|"AIDER DIRECT"| AIDER
    AIDER -->|"in_progress / done"| DB
    AIDER -->|"run fails / tests fail"| DEBUGGER
    DEBUGGER --> DB
    DEBUGGER -->|"failure / trace"| PI
    DEBUGGER -->|"trace / test fail"| AIDER
    DEBUGGER -->|"schema/environment\nreroute"| ORCH
    DEBUGGER -->|"logic + low confidence"| THINKER
    ORACLE --> DB
    ORACLE -->|"plan"| COUNCIL
    GEMMA_PLANNER --> DB
    GEMMA_PLANNER -->|"plan"| COUNCIL
    COUNCIL -->|"consensus spec"| ORCH
    THINKER --> DB
    THINKER -->|"root constraint"| ORCH
    RESEARCHER --> DB
    RESEARCHER -->|"raw evidence"| SUMMARIZER
    SUMMARIZER --> DB
    SUMMARIZER -->|"SPO triplets /\nevidence pack"| ORCH
    SUMMARIZER -->|"compressed evidence"| THINKER
    OBSERVER --> DB
    OBSERVER -->|"raw evidence"| SUMMARIZER
    HANDYMAN --> DB
    DB -->|"heartbeat / status"| ORCH

    classDef entry fill:#1a1a2e,stroke:#4fc3f7,color:#e0e0e0,rx:8
    classDef shell fill:#0d2137,stroke:#4fc3f7,color:#e0e0e0,rx:4
    classDef primary fill:#1b2a1b,stroke:#81c784,color:#e0e0e0,rx:4
    classDef subagent fill:#2a1b0d,stroke:#ffb74d,color:#e0e0e0,rx:4
    classDef leaf fill:#2a0d1b,stroke:#f06292,color:#ffffff,rx:4,stroke-width:2px
    classDef db fill:#1a1a1a,stroke:#9e9e9e,color:#e0e0e0
    classDef watchdog fill:#1a0d2a,stroke:#ce93d8,color:#e0e0e0,rx:8

    class HUMAN,RAG entry
    class HB watchdog
    class OC shell
    class ORCH,ORACLE,GEMMA_PLANNER,THINKER,OBSERVER,RESEARCHER,FIXER,COUNCIL primary
    class SCOUT,PATCHER,PI,DEBUGGER,HANDYMAN,SUMMARIZER subagent
    class AIDER leaf
    class DB db



