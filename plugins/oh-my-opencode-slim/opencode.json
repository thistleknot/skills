{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwopus-coder-oc:9b",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://192.168.3.122:11434/v1",
        "timeout": 480000
      },
      "models": {
        "qwen3.5-oc:2b": {
          "variants": {
            "orchestrator": {
              "limit": { "output": 512 },
              "reasoning": { "effort": "low", "enabled": true }
            },
            "io": { "reasoning": { "effort": "none", "exclude": true } }
          }
        },
        "qwen3.5-reasoning-oc:9b": {
          "variants": {
            "tactical": { "reasoning": { "effort": "medium" } },
            "heavy": {
              "reasoning": { "effort": "high", "enabled": true },
              "modelKwargs": { "frequency_penalty": 0.4, "presence_penalty": 0.2 }
            },
            "orchestrator": {
              "reasoning": { "effort": "high", "enabled": true },
              "modelKwargs": { "frequency_penalty": 0.4, "presence_penalty": 0.2 }
            }
          }
        },
        "qwopus-coder-oc:9b": {
          "variants": {
            "lean": {
              "reasoning": { "effort": "minimal" },
              "modelKwargs": { "frequency_penalty": 0.7, "presence_penalty": 0.2 }
            },
            "io": { "reasoning": { "effort": "none", "exclude": true } },
            "orchestrator": {
              "reasoning": { "effort": "high", "enabled": true },
              "modelKwargs": { "frequency_penalty": 0.4, "presence_penalty": 0.2 }
            }
          }
        },
        "qwen3-vl:2b": {
          "variants": {
            "vision_audit": { "reasoning": { "effort": "medium", "enabled": true } }
          }
        },
        "hf.co/Jackrong/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-v2-GGUF:Qwen3.5-9B.Q5_K_M.gguf": {
          "variants": {
            "planner": {
              "reasoning": { "effort": "high", "enabled": true },
              "modelKwargs": { "num_ctx": 32768, "frequency_penalty": 0.4, "presence_penalty": 0.2 }
            }
          }
        },
        "qwen3.5-oc:4b": {
          "variants": {
            "lean": {
              "reasoning": { "effort": "minimal" },
              "modelKwargs": { "frequency_penalty": 0.7, "presence_penalty": 0.2 }
            }
          }
        }
      }
    }
  },
  "mcp": {
    "memory-bank": {
      "type": "local",
      "command": [
        "python",
        "C:\\Users\\user\\.copilot\\memory_mcp.py"
      ],
      "enabled": true
    },
    "todo": {
      "type": "local",
      "command": [
        "python",
        "C:\\Users\\user\\Documents\\dev\\skills\\todo\\todo_mcp.py"
      ],
      "enabled": true
    },
    "task-graph": {
      "type": "local",
      "command": [
        "python",
        "C:\\Users\\user\\Documents\\dev\\skills\\todo\\task_graph_mcp.py"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "agent": {
    "orchestrator": {
      "timeout": 300000,
      "permission": {
        "read": "deny",
        "grep": "deny",
        "glob": "deny",
        "list": "deny",
        "bash": "allow",
        "edit": "allow",
        "subtask": "allow"
      }
    },
    "coder": {
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "bash": "allow",
        "edit": "allow",
        "subtask": "allow"
      }
    },
    "aider": {
      "timeout": 300000,
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "bash": "allow",
        "edit": "allow",
        "subtask": "deny"
      }
    },
    "summarizer": {
      "permission": {
        "read": "allow",
        "grep": "deny",
        "glob": "deny",
        "list": "deny",
        "bash": "deny",
        "edit": "deny",
        "subtask": "deny"
      }
    }
  },
  "lsp": true
