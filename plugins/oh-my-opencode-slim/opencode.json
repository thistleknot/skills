{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/deepseek/deepseek-v4-flash",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://192.168.3.17:11434/v1",
        "timeout": 480000
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "timeout": 480000
      },
      "models": {
        "google/gemma-4-26b-a4b-it": {
          "name": "Gemma 4 26B Strategic",
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "variants": {
            "strategic": {
              "reasoning": {
                "effort": "high",
                "enabled": true
              },
              "modelKwargs": {
                "frequency_penalty": 1.4,
                "presence_penalty": 1.2
              }
            },
            "orchestrator": {
              "limit": { "output": 512 },
              "reasoning": {
                "effort": "medium",
                "enabled": true
              },
              "modelKwargs": {
                "frequency_penalty": 1.3,
                "presence_penalty": 1.1
              }
            },
            "fast": {
              "reasoning": {
                "effort": "minimal",
                "exclude": true
              }
            },
            // Independent planner variants (Plan B in dual-planner panel).
            // Active: planner_conservative — suppresses gemma's repetition loop problem.
            // Switch to planner_balanced or planner_creative if output is too terse.
            "planner_balanced": {
              "reasoning": {
                "effort": "medium",
                "enabled": true
              },
              "modelKwargs": {
                "temperature": 0.7,
                "top_p": 0.9,
                "frequency_penalty": 1.4,
                "presence_penalty": 1.2
              }
            },
            "planner_conservative": {
              "reasoning": {
                "effort": "low",
                "enabled": true
              },
              "modelKwargs": {
                "temperature": 0.1,
                "top_p": 1.0,
                "frequency_penalty": 1.6,
                "presence_penalty": 1.4
              }
            },
            "planner_creative": {
              "reasoning": {
                "effort": "high",
                "enabled": true
              },
              "modelKwargs": {
                "temperature": 1.2,
                "top_p": 0.95,
                "frequency_penalty": 1.4,
                "presence_penalty": 1.2
              }
            }
          }
        },
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "limit": {
            "context": 1048576,
            "output": 393216
          },
